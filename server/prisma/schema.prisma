// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  password            String?
  firstName           String
  surname             String
  subscribed          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  bodyweight   Float?   // in kg
  height       Float?   // in cm
  birthday     DateTime? // Date of birth instead of age
  gender       String?  // e.g., "Male", "Female", "Non-binary", etc.
  profilePhoto String?  // URL or file path to profile photo

  // Referral fields
  referralCode        String?  @unique
  referredBy          String?
  referralCredits     Int      @default(0)  // Credits earned from referrals
  freeMonthsEarned    Int      @default(0)  // Total free months earned
  freeMonthsUsed      Int      @default(0)  // Free months already applied
  
  // Referral relationships
  referrer            User?    @relation("UserReferrals", fields: [referredBy], references: [id])
  referredUsers       User[]   @relation("UserReferrals")

  passwordResetToken   String?   
  passwordResetExpires DateTime?

  // Rolling window consistency streak fields
  streak_count             Int      @default(0)
  streak_goal              Int      @default(3)
  current_window_start     DateTime?
  current_window_workouts  Int      @default(0)
  streak_freeze_available  Boolean  @default(true)
  last_workout_at          DateTime?

  userPrograms         UserProgram[]
  bodyweightEntries    BodyweightEntry[]
  bodyfatEntries       BodyfatEntry[]
  exerciseProgressions UserExerciseProgression[]
}

model Programme {
  id          String   @id @default(cuid())
  name        String
  daysPerWeek Int      @map("days_per_week")
  weeks       Int
  bodyPartFocus String @map("body_part_focus") // Full Body, Upper Body, Lower Body, etc.
  progressionFocus ProgrammeProgressionFocus @default(MUSCLE_BUILDING) @map("progression_focus")
  description String?
  isCustom    Boolean  @default(false) @map("is_custom")
  userId      String?  @map("user_id")
  experienceLevel String? @map("experience_level")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relationships
  exercises   ProgrammeExercise[]
  userPrograms UserProgram[]

  @@map("programmes")
}

model Exercise {
  id          String   @id @default(cuid())
  name        String
  muscleGroup String   @map("muscle_group")
  category    String
  equipment   String?
  isSelected  Boolean  @default(false)
  instructions String?
  movementPattern         String?  @map("movement_pattern")
  defaultRepMin           Int?     @map("default_rep_min")
  defaultRepMax           Int?     @map("default_rep_max")
  complementaryExerciseIds String? @map("complementary_exercise_ids")
  replacementExerciseIds   String? @map("replacement_exercise_ids")
  isCustom                 Boolean @default(false) @map("is_custom")
  createdByUserId          String? @map("created_by_user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relationships
  programmeExercises   ProgrammeExercise[]
  workoutExercises     WorkoutExercise[]
  exerciseProgressions UserExerciseProgression[]

  @@index([muscleGroup])
  @@map("exercises")
}

model ProgrammeExercise {
  id          String @id @default(cuid())
  programmeId String @map("programme_id")
  exerciseId  String @map("exercise_id")
  dayNumber   Int    @map("day_number") // 1, 2, 3, etc. for each day of the week
  orderIndex  Int    @map("order_index") // Order of exercise within the day
  sets        Int    @default(3)
  reps        String @default("8-12") // Can be "8-12", "10", "AMRAP", etc.
  strengthRole StrengthExerciseRole @default(ACCESSORY) @map("strength_role")
  restSeconds Int?   @map("rest_seconds") // Rest between sets in seconds
  isSelected  Boolean  @default(false) // Selected as part of programme or not
  notes       String?

  // Relationships
  programme Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  exercise  Exercise  @relation(fields: [exerciseId], references: [id])

  @@index([programmeId])
  @@map("programme_exercises")
}

model UserProgram {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  programmeId String            @map("programme_id")
  startDate   DateTime          @map("start_date")
  endDate     DateTime?         @map("end_date")
  currentWeek Int               @default(1) @map("current_week")
  currentDay  Int               @default(1) @map("current_day")
  status      UserProgramStatus @default(ACTIVE)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relationships
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  programme            Programme                 @relation(fields: [programmeId], references: [id])
  workouts             Workout[]
  exerciseProgressions UserExerciseProgression[]

  @@index([userId, status])
  @@map("user_programs")
}

model Workout {
  id            String   @id @default(cuid())
  userProgramId String   @map("user_program_id")
  weekNumber    Int      @map("week_number")
  dayNumber     Int      @map("day_number")
  completedAt   DateTime @map("completed_at")
  duration      Int?     // Duration in minutes
  notes         String?
  skipped       Boolean  @default(false)
  perceivedDifficulty Int? @map("perceived_difficulty")
  startRecovery      String? @map("start_recovery")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relationships
  userProgram UserProgram       @relation(fields: [userProgramId], references: [id], onDelete: Cascade)
  exercises   WorkoutExercise[]

  @@index([userProgramId, completedAt])
  @@map("workouts")
}

model WorkoutExercise {
  id         String @id @default(cuid())
  workoutId  String @map("workout_id")
  exerciseId String @map("exercise_id")
  orderIndex Int    @map("order_index")

  // Relationships
  workout  Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise      @relation(fields: [exerciseId], references: [id])
  sets     WorkoutSet[]

  @@index([workoutId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

model WorkoutSet {
  id                String          @id @default(uuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setNumber         Int
  weight            Float?
  reps              Int?
  targetReps        Int?           // Add this field for tracking target vs actual
  rpe               Int?
  restSeconds       Int?
  notes             String?
  completed         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([workoutExerciseId])
}

model UserExerciseProgression {
  id                         String    @id @default(cuid())
  userId                     String    @map("user_id")
  userProgramId              String    @map("user_program_id")
  exerciseId                 String    @map("exercise_id")
  progressionPhase           String    @default("rep_progression") @map("progression_phase")
  consecutiveSessionsAtMaxReps Int     @default(0) @map("consecutive_sessions_at_max_reps")
  weeksAtCurrentSetCount     Int       @default(0) @map("weeks_at_current_set_count")
  lastWeightIncreaseAt       DateTime? @map("last_weight_increase_at")
  lastSetIncreaseAt          DateTime? @map("last_set_increase_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userProgram UserProgram @relation(fields: [userProgramId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id])

  @@unique([userProgramId, exerciseId])
  @@map("user_exercise_progressions")
}

model BodyweightEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  weight    Float    // in kg
  date      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("bodyweight_entries")
}

model BodyfatEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  bodyfat   Float    // percentage
  date      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("bodyfat_entries")
}

enum UserProgramStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum ProgrammeProgressionFocus {
  MUSCLE_BUILDING
  STRENGTH
}

enum StrengthExerciseRole {
  MAIN_LIFT
  SUPPLEMENTAL
  ACCESSORY
}